<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Błąd — WI Monitor</title>
  <link rel="stylesheet" href="/stylesheets/app.css">
</head>
<body>
  <main class="container" style="text-align:center;padding-top:4rem">
    <h1><%= typeof message !== 'undefined' ? message : 'Wystąpił błąd' %></h1>
    <p>Status: <%= typeof error !== 'undefined' && error.status ? error.status : 500 %></p>
    <% if (typeof error !== 'undefined' && error.stack && process.env.NODE_ENV !== 'production') { %>
      <pre style="text-align:left;margin-top:2rem;background:#f5f5f5;padding:1rem;border-radius:8px"><%= error.stack %></pre>
    <% } %>
    <a href="/" class="btn btn-primary" style="margin-top:2rem">Powrót do panelu</a>
  </main>
</body>
</html>
